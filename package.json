{
  "name": "cmdcontract",
  "version": "0.1.0",
  "description": "Executable CLI contract specs that keep README commands honest.",
  "type": "module",
  "bin": {
    "cmdcontract": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "examples",
    "contracts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "node --test test/*.test.js",
    "smoke": "npm run build && node dist/cli.js run examples/contracts/happy.yaml --format tap && node dist/cli.js init --from examples/README-fixture.md --out .cmdcontract/smoke-readme.yaml && node dist/cli.js report examples/results/sample-results.json --format markdown",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm test && npm run package:smoke"
  },
  "keywords": [
    "cli",
    "contracts",
    "doctest",
    "documentation",
    "testing",
    "fixtures",
    "local-first"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "dependencies": {
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/cmdcontract.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/cmdcontract/issues"
  },
  "homepage": "https://github.com/rogerchappel/cmdcontract#readme"
}
